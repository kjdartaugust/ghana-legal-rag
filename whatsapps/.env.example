# Godspeed WhatsApp Bot - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub!

# Server
PORT=3000

# MongoDB Atlas (Get this from MongoDB Atlas dashboard)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/godspeed?retryWrites=true&w=majority

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=your_new_meta_access_token_here
META_PHONE_NUMBER_ID=1161864803674689
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Owner Alerts (your personal WhatsApp number for notifications)
OWNER_PHONE_NUMBER=233558514238

# Business Context (optional - add specific services here later)
# BUSINESS_CONTEXT="We offer graphic design, phone accessories, and delivery services"
